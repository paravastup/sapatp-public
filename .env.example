# ATP Application Environment Configuration
# Copy this to .env and update with your actual values
# NEVER commit .env to version control!

# Django Settings
DJANGO_SECRET_KEY=CHANGE_THIS_TO_NEW_GENERATED_KEY
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
DATABASE_ENGINE=django.db.backends.mysql
DATABASE_NAME=atp
DATABASE_USER=dbuser
DATABASE_PASSWORD=CHANGE_THIS_DATABASE_PASSWORD
DATABASE_HOST=db
DATABASE_PORT=3306

# SAP Connection Settings
SAP_HOST=your-sap-host-ip
SAP_SYSNR=00
SAP_CLIENT=100
SAP_USER=your-sap-user
SAP_PASSWORD=CHANGE_THIS_SAP_PASSWORD
SAP_LANG=EN

# Email Configuration (Optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-app-specific-password
EMAIL_USE_TLS=True

# Security Settings
SESSION_COOKIE_AGE=3600
SECURE_SSL_REDIRECT=False